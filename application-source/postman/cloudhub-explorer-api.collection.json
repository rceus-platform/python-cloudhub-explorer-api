		{
			"name": "Files",
			"item": [
				{
					"name": "List Files (Root)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/files/?folder_id=root",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"files",
								""
							],
							"query": [
								{
									"key": "folder_id",
									"value": "root"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Stream File",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/files/stream?provider=mega&file_id=123&_file_name=video.mp4&account_id=1",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"files",
								"stream"
							],
							"query": [
								{
									"key": "provider",
									"value": "mega"
								},
								{
									"key": "file_id",
									"value": "123"
								},
								{
									"key": "_file_name",
									"value": "video.mp4"
								},
								{
									"key": "account_id",
									"value": "1"
								}
							]
						},
						"description": "Streams a file from the provider with range-request support. Uses account_id to distinguish between multiple accounts."
					},
					"response": []
				}
			]
		},
